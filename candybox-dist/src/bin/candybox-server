#!/usr/bin/env bash
#
# Starts a Candybox storage node in the FOREGROUND (logs to stdout, no daemonization) so a process
# supervisor or container orchestrator owns its lifecycle. SIGTERM/Ctrl-C triggers a graceful
# shutdown that releases the node's ownership leases.
#
# Usage: candybox-server [path/to/candybox.properties]
#   Defaults to $CANDYBOX_CONF_DIR/candybox.properties.
#
# Set CANDYBOX_DRY_RUN=1 to print the resolved java command instead of executing it.
#
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=candybox-env.sh
source "$BIN_DIR/candybox-env.sh"

CONFIG_FILE="${1:-$CANDYBOX_CONF_DIR/candybox.properties}"
if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "ERROR: configuration file not found: $CONFIG_FILE" >&2
  echo "Copy $CANDYBOX_CONF_DIR/candybox.properties.example to candybox.properties and edit it," >&2
  echo "or pass a config path as the first argument." >&2
  exit 1
fi

mkdir -p "$CANDYBOX_LOG_DIR"

CMD=("$JAVA" "${CANDYBOX_JVM_OPTS[@]}" -cp "$CLASSPATH"
     me.predatorray.candybox.server.CandyboxServer "$CONFIG_FILE")

if [[ -n "${CANDYBOX_DRY_RUN:-}" ]]; then
  printf '%s ' "${CMD[@]}"
  printf '\n'
  exit 0
fi

exec "${CMD[@]}"
